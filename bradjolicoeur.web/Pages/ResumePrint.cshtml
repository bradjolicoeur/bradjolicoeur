@page "/resume/print"
@model ResumePrintModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Brad Jolicoeur — Resume</title>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            font-family: 'Georgia', serif;
            font-size: 11pt;
            color: #1a1a1a;
            line-height: 1.5;
            padding: 0.75in 0.75in;
            max-width: 8.5in;
            margin: 0 auto;
        }
        h1 { font-size: 20pt; font-weight: bold; margin-bottom: 2px; }
        h2 { font-size: 13pt; border-bottom: 1px solid #333; margin-top: 18px; margin-bottom: 8px; padding-bottom: 3px; }
        h3 { font-size: 11pt; font-weight: bold; margin-top: 12px; margin-bottom: 4px; }
        h4 { font-size: 11pt; font-weight: bold; margin-top: 10px; margin-bottom: 2px; }
        p { margin-bottom: 6px; }
        ul { padding-left: 18px; margin-bottom: 8px; }
        li { margin-bottom: 3px; }
        a { color: #1a1a1a; text-decoration: none; }
        strong { font-weight: bold; }
        .print-controls { margin-bottom: 20px; }
        .print-controls button {
            background: #333;
            color: white;
            border: none;
            padding: 8px 16px;
            cursor: pointer;
            border-radius: 4px;
            font-size: 12px;
            margin-right: 8px;
        }
        @@media print {
            .print-controls { display: none; }
            body { padding: 0; }
            @@page { margin: 0.5in; }
        }
    </style>
</head>
<body>
    <div class="print-controls">
        <button onclick="window.print()">🖨 Print / Save as PDF</button>
        <button onclick="window.close()">✕ Close</button>
    </div>
    <div>
        @Html.Raw(MarkdownHelper.Transform(Model.Resume?.Body))
    </div>
    <script>
        // Auto-trigger print dialog when opened from the download button
        // Small delay to ensure styles are applied
        if (window.opener) {
            setTimeout(() => window.print(), 500);
        }
    </script>
</body>
</html>
