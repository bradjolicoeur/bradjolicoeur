@page "/privacy-policy"
@model PrivacyModel
@{
    ViewData["Title"] = "Privacy Policy";
    ViewBag.Description = "Privacy policy for bradjolicoeur.com — how your information is collected and used.";
}

<div class="container" style="max-width: 800px; margin: 3rem auto; padding: 0 1.5rem;">
    @Html.Raw(MarkdownHelper.Transform(Model.PageData?.Body))
</div>
