@page
@model ResumeModel
@{
    ViewData["Title"] = "Resume";
    ViewBag.Description = "Brad Jolicoeur — Principal Architect, Production AI, Engineering Leadership";
}
@section Scripts {
<script>
function downloadResumePdf() {
    window.open('/resume/print', '_blank');
}
</script>
}
<div class="container">
    <div class="row mb-3">
        <div class="col">
            <button onclick="window.open('/resume/print', '_blank')" class="btn btn-outline-secondary btn-sm">
                ⬇ Download PDF
            </button>
        </div>
    </div>
    <div class="row resume">
        @Html.Raw(MarkdownHelper.Transform(Model.Resume?.Body))
    </div>
</div>
